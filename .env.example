# Copy to .env and fill in (never commit .env — see .gitignore)

# Required for the API to start
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Optional: comma-separated origins for browser clients (Flutter web). Leave empty for allow_origins=* and credentials=false.
# Example: CORS_ALLOWED_ORIGINS=https://your-app.web.app,https://www.example.com
CORS_ALLOWED_ORIGINS=
# When CORS_ALLOWED_ORIGINS is set: true only if you need credentialed cross-origin requests (cookies).
CORS_ALLOW_CREDENTIALS=false

# Optional: protects GET /api/admin/stats (header X-Admin-Key). Leave empty to disable the endpoint (503).
ADMIN_API_KEY=

# Optional: default for GET /api/practice/download-pack when the client omits backfill= (true|false). Empty/false = no Claude backfill on download.
DOWNLOAD_PACK_BACKFILL_DEFAULT=false

# POST /api/tutor/chat uses the same ANTHROPIC_* keys (scoped exam tutor; no extra env).
